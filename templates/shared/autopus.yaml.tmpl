# autopus.yaml — {{.ProjectName}}
# Autopus-ADK 하네스 설정 파일
# 이 파일을 수정하여 프로젝트에 맞게 커스터마이징하세요.

mode: full
project_name: {{.ProjectName}}
platforms:
{{range .Platforms}}  - {{.}}
{{end}}
architecture:
  auto_generate: {{.Architecture.AutoGenerate}}
  enforce: {{.Architecture.Enforce}}
{{if .Architecture.Layers}}  layers:
{{range .Architecture.Layers}}    - {{.}}
{{end}}{{end}}
lore:
  enabled: {{.Lore.Enabled}}
  auto_inject: {{.Lore.AutoInject}}
  stale_threshold_days: {{.Lore.StaleThresholdDays}}
{{if .Lore.RequiredTrailers}}  required_trailers:
{{range .Lore.RequiredTrailers}}    - {{.}}
{{end}}{{end}}
spec:
  id_format: "{{.Spec.IDFormat}}"
{{if .Spec.EARSTypes}}  ears_types:
{{range .Spec.EARSTypes}}    - {{.}}
{{end}}{{end}}

methodology:
  mode: tdd
  enforce: true
  review_gate: true

router:
  strategy: balanced
  tiers:
    economy: gemini
    smart: codex
    ultra: opus
  categories:
    visual: smart
    deep: ultra
    quick: economy
    ultrabrain: ultra
    writing: smart
    git: economy
    adaptive: smart
  intent_gate: true

hooks:
  pre_commit_arch: true
  pre_commit_lore: true
  react_ci_failure: true
  react_review: true

session:
  handoff_enabled: true
  continue_file: .auto-continue.md
  max_context_tokens: 2000

orchestra:
  enabled: true
  default_strategy: consensus
  timeout_seconds: 120
  providers:
    claude:
      binary: claude
      args: ["-p", "", "--output-format", "json", "--dangerously-skip-permissions"]
      pane_args: ["--print", "--model", "opus", "--effort", "high", "--dangerously-skip-permissions"]
      prompt_via_args: true
      subprocess:
        schema_flag: "--json-schema"
        output_format: "json"
    codex:
      binary: codex
      args: ["exec", "--full-auto", "--output-last-message", "-", ""]
      pane_args: []
      prompt_via_args: true
      subprocess:
        schema_flag: "--output-schema"
        output_format: "json"
    gemini:
      binary: gemini
      args: ["-m", "gemini-1.5-flash", "--output-format", "json", "-p", ""]
      pane_args: ["-m", "gemini-1.5-flash"]
      prompt_via_args: true
      subprocess:
        output_format: "json"
  commands:
    plan:
      strategy: consensus
      providers: [claude, codex, gemini]
    review:
      strategy: debate
      providers: [claude, codex, gemini]
    secure:
      strategy: consensus
      providers: [claude, codex, gemini]
    brainstorm:
      strategy: debate
      providers: [claude, codex, gemini]

quality:
  default: ultra
  presets:
    balanced:
      description: 설계는 Claude(Opus), 구현은 Codex(Sonnet), 리뷰는 Gemini(Haiku).
      agents:
        architect: opus
        debugger: sonnet
        devops: sonnet
        executor: sonnet
        explorer: sonnet
        planner: opus
        reviewer: haiku
        security-auditor: opus
        spec-writer: opus
        tester: sonnet
        validator: sonnet
    ultra:
      description: 모든 에이전트를 Opus로 실행. 최고 품질.
      agents:
        architect: opus
        debugger: opus
        devops: opus
        executor: opus
        explorer: opus
        planner: opus
        reviewer: opus
        security-auditor: opus
        spec-writer: opus
        tester: opus
        validator: opus
